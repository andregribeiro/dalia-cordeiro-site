---
// Root redirect: detect browser language and bounce to /pt/ or /en/
---

<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0;url=/pt/" />
    <script is:inline>
      const lang = (navigator.language || '').slice(0, 2);
      if (lang === 'en') window.location.replace('/en/');
    </script>
  </head>
  <body></body>
</html>
