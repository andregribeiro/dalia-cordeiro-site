---
import type { Lang } from '../lib/i18n';
import { t, routes, getAlternateLang } from '../lib/i18n';

interface Props {
  lang: Lang;
  active?: 'works' | 'about' | 'contact';
  instagramUrl?: string;
  /** Override the alternate-language URL (computed from routes by default) */
  altUrl?: string;
}

const { lang, active, instagramUrl = 'https://www.instagram.com/dalia_cordeiro_art/', altUrl: altUrlProp } = Astro.props;
const altLang = getAlternateLang(lang);
const r = routes[lang];
const altR = routes[altLang];

// Compute alternate URL: match current page to its route, then map to alt lang
function computeAltUrl(): string {
  const path = Astro.url.pathname;
  if (path === r.home) return altR.home;
  if (path === r.about) return altR.about;
  if (path === r.contact) return altR.contact;
  return altR.home;
}

const altUrl = altUrlProp ?? computeAltUrl();
const enUrl = lang === 'en' ? Astro.url.pathname : altUrl;
const ptUrl = lang === 'pt' ? Astro.url.pathname : altUrl;
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href={r.home}>Dália <span>Cordeiro</span></a>
    <nav class="nav">
      <a href={r.home} class={active === 'works' ? 'active' : ''}>{t(lang, 'nav_works')}</a>
      <a href={r.about} class={active === 'about' ? 'active' : ''}>{t(lang, 'nav_about')}</a>
      <a href={r.contact} class={active === 'contact' ? 'active' : ''}>{t(lang, 'nav_contact')}</a>
    </nav>
    <div class="header-right">
      <div class="lang-switch">
        <a href={enUrl} class={lang === 'en' ? 'on' : ''}>EN</a>
        <span class="sep">/</span>
        <a href={ptUrl} class={lang === 'pt' ? 'on' : ''}>PT</a>
      </div>
      <a class="ig-link" href={instagramUrl} target="_blank" rel="noreferrer" title="Instagram">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <rect x="3" y="3" width="18" height="18" rx="4"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="0.9" fill="currentColor"/>
        </svg>
      </a>
    </div>
  </div>
</header>
